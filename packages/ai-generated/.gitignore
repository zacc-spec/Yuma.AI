# AI-Generated Files - What to Ignore

# Temporary files
*.tmp
*.temp
*.log
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Build artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Node modules (if any JS scripts)
node_modules/
package-lock.json

# IDE files
.vscode/
.idea/
*.iml

# Test outputs
.coverage
htmlcov/
.pytest_cache/
test-results/

# Environment files (NEVER commit!)
.env
.env.local
.env.*.local
secrets.yaml
*.key
*.pem

# Archives
archive/
*.tar.gz
*.zip

# Generated output files (scripts produce output)
output/
results/
*.csv
*.json
*.txt
(unless tracked)

# Debug files
debug/
*.debug
*.trace

# Keep these in .gitignore but DO commit important scripts:
# - Production-ready scripts (before moving to bin/)
# - Configuration templates
# - Shared utilities
# - Documentation
